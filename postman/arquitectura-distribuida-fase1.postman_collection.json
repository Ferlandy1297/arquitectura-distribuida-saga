              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('estado COMPLETADO', () => pm.expect(json.estado).to.eql('COMPLETADO'));",
              "pm.environment.set('pedido_id', json.id);"
            ],
