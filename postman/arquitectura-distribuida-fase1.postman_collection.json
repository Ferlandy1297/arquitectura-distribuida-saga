{
  "info": {
    "name": "arquitectura-distribuida-fase1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Inventario - GET lista",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_inventario}}/inventario", "host": ["{{base_inventario}}"], "path": ["inventario"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Array de inventario', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Inventario - POST reservar",
      "request": {
        "method": "POST",
        "header": [ {"key":"Content-Type","value":"application/json"} ],
        "body": { "mode": "raw", "raw": "{\n  \"producto\": \"Laptop\",\n  \"cantidad\": 2\n}" },
        "url": { "raw": "{{base_inventario}}/inventario/reservar", "host": ["{{base_inventario}}"], "path": ["inventario","reservar"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('success true', () => pm.expect(json.success).to.eql(true));",
              "pm.test('stockActual presente', () => pm.expect(json).to.have.property('stockActual'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
